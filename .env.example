# LLM SECURITY AUDITOR - ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values

# LLM API Keys
GROQ_API_KEY=****
NVIDIA_API_KEY=****

# MongoDB Configuration
MONGODB_URI=****
MONGODB_DB_NAME=llm_security_auditor

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
API_PORT=8000

# Model Configuration
ATTACKER_MODEL=llama-3.1-8b-instant
JUDGE_MODEL=llama-3.3-70b-versatile
TARGET_MODEL_PROVIDER=nvidia
TARGET_MODEL_NAME=meta/llama3-70b-instruct

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=30
REQUEST_TIMEOUT=60

# Paths
DATA_DIR=./data
LOGS_DIR=./logs
